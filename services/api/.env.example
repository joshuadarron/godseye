# Database
DATABASE_URL=postgres://godseye:godseye@localhost:5433/globaltracker?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# Server
SERVER_ADDR=:8080

# JWT (must match auth service)
JWT_SECRET=

# OpenSky Network — free, register at https://opensky-network.org/
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# AISHub
AISHUB_USERNAME=

# AISStream — free, register at https://aisstream.io/
AISSTREAM_API_KEY=

# ACLED — free for research, register at https://acleddata.com/
ACLED_API_KEY=
ACLED_EMAIL=

# Ticketmaster
TICKETMASTER_API_KEY=

# PredictHQ
PREDICTHQ_API_KEY=

# OpenWeatherMap
OPENWEATHER_API_KEY=

# Memgraph (graph database for proximity/topology)
MEMGRAPH_BOLT_URL=bolt://localhost:7687
MEMGRAPH_USER=memgraph
MEMGRAPH_PASSWORD=memgraph

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
